<Page x:Class="Demo2.Pages.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">

    <Grid>
        <Grid Height="50" Background="LightSeaGreen" VerticalAlignment="Top">
            <Label 
                Foreground="White"
                Content="Бронирование номеров"
                FontSize="14"
                FontWeight="Bold"
                VerticalContentAlignment="Center"
                Margin="10"/>
            <Button
                Content="Добавить"
                Click="Add"
                Width="100"
                Margin="10"
                HorizontalAlignment="Right"
                Background="White"/>
        </Grid>
        <ScrollViewer Margin="10,60,10,10">
            <StackPanel x:Name="spItems">
               
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
