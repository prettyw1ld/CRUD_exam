<Page x:Class="Demo2.Pages.Add"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Demo2.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Add">

    <Grid>
        <Grid Height="50" Background="LightSeaGreen" VerticalAlignment="Top">
            <Label 
                Foreground="White"
                Content="Добавить номер"
                FontSize="14"
                FontWeight="Bold"
                VerticalContentAlignment="Center"
                Margin="10"/>
            <Button
                Content="Добавить"
                Click="Save"
                Width="100"
                Margin="10"
                HorizontalAlignment="Right"
                Background="White"/>
            <Button
                Content="Назад"
                Margin="0,10,130,10"
                Click="Back"
                Background="White" HorizontalAlignment="Right" Width="100"/>
        </Grid>

        <Grid Background="White" Margin="10,60,10,10" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Label
                VerticalAlignment="Top"
                Height="25" Content="Дата" Grid.Column="0"/>
            <DatePicker
                x:Name="tbDate"
                VerticalAlignment="Top"
                Height="25"
                Margin="0,25,0,0"
                Grid.Column="0"/>

            <Label
                 VerticalAlignment="Top" Margin="0,50,0,0"
                 Height="25" Content="Продолжительность" Grid.Column="0"/>
            <TextBox
                 x:Name="tbDuration"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,75,0,0"
                 Grid.Column="0"/>

            <Label
                 VerticalAlignment="Top" Margin="0,100,0,0"
                 Height="25" Content="ФИО" Grid.Column="0"/>
            <TextBox
                 x:Name="tbFIO"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,125,0,0"
                Grid.Column="0"/>
            <Label
                VerticalAlignment="Top" Margin="0,150,0,0"
                Height="25" Content="Отель" Grid.Column="0"/>
            <ComboBox
                 x:Name="tbHostel"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,175,0,0"
                Grid.Column="0"/>


            <Label
                 VerticalAlignment="Top"
                 Height="25" Content="Время" Grid.Column="2"/>
            <TextBox
                 x:Name="tbTime"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,25,0,0"
                 Grid.Column="2"/>

            <Label
                 VerticalAlignment="Top" Margin="0,50,0,0"
                 Height="25" Content="Номер телефона" Grid.Column="2"/>
            <TextBox
                 x:Name="tbPhone"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,75,0,0"
                Grid.Column="2"/>
            <Label
                VerticalAlignment="Top" Margin="0,100,0,0"
                Height="25" Content="Паспортные данные" Grid.Column="2"/>
            <TextBox
                 x:Name="tbSerialNumber"
                 VerticalAlignment="Top"
                 Height="25"
                 Margin="0,125,0,0"
                Grid.Column="2"/>
        </Grid>
    </Grid>
</Page>
